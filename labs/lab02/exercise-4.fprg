    </attributes>
    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="DistanceKM" type="Real" array="False" size=""/>
            <input variable="DistanceKM"/>
            <declare name="Litre" type="Real" array="False" size=""/>
            <assign variable="Litre" expression="(DistanceKM/100) * 8"/>
            <declare name="Cost" type="Real" array="False" size=""/>
            <assign variable="Cost" expression="Litre * 2.05"/>
            <output expression="Cost" newline="True"/>
        </body>
    </function>
</flowgorithm>
